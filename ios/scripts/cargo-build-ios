#!/bin/bash
# Cargo build script invoked as an Xcode build phase.
# Builds the zed-ios static library and copies libzed_ios.a to BUILT_PRODUCTS_DIR.
#
# This script runs on EVERY Xcode build (alwaysOutOfDate = 1 in the project
# file) because Xcode cannot track Rust source dependencies. Cargo's own
# incrementality makes no-op builds fast (~1s). The copy step uses rsync
# --checksum so Xcode only re-links when the library actually changed.

set -euo pipefail

# Xcode runs scripts with a stripped PATH. Restore cargo and common tool paths.
export PATH="$HOME/.cargo/bin:/opt/homebrew/bin:/usr/local/bin:$PATH"
if [ -f "$HOME/.cargo/env" ]; then
    source "$HOME/.cargo/env"
fi

REPO_ROOT="$(cd "$PROJECT_DIR/.." && pwd)"

# Select Rust target based on the Xcode platform being built.
if [ "$PLATFORM_NAME" = "iphonesimulator" ]; then
    RUST_TARGET="aarch64-apple-ios-sim"
else
    RUST_TARGET="aarch64-apple-ios"
fi

# Always build with --release. In debug builds, rust-embed loads assets from
# the filesystem at the compile-time path, which doesn't exist inside the iOS
# app sandbox. Release mode embeds assets into the binary at compile time.
# This also avoids shipping multi-gigabyte debug binaries to devices.
CARGO_FLAGS="--release"
CARGO_PROFILE_DIR="release"

echo "Building zed-ios for $RUST_TARGET ($CONFIGURATION)..."

# All Apple Silicon chips (A11+) support FP16 NEON. Enable it so that crates
# using half-precision inline assembly (gemm-f16, pulled in via candle/audio)
# compile without errors on the aarch64-apple-ios target.
export RUSTFLAGS="${RUSTFLAGS:-} -C target-feature=+fp16"

cd "$REPO_ROOT"
cargo build \
    -p zed-ios \
    --target "$RUST_TARGET" \
    $CARGO_FLAGS \
    --no-default-features

LIB_SRC="$REPO_ROOT/target/$RUST_TARGET/$CARGO_PROFILE_DIR/libzed_ios.a"
LIB_DST="$BUILT_PRODUCTS_DIR/libzed_ios.a"

# Only copy when the binary differs. This preserves the destination mtime so
# Xcode's linker skips re-linking on true no-op cargo builds.
if ! cmp -s "$LIB_SRC" "$LIB_DST" 2>/dev/null; then
    cp "$LIB_SRC" "$LIB_DST"
    echo "Copied $LIB_SRC → $LIB_DST"
else
    echo "libzed_ios.a unchanged, skipping copy"
fi
