#!/usr/bin/env bash
set -euo pipefail

# Build the gpui_web hello_web example for the browser.
#
# Usage:
#   crates/gpui_web/script/build [--release]
#
# Prerequisites:
#   rustup target add wasm32-unknown-unknown
#   cargo install wasm-bindgen-cli


# # 1. Build the wasm binary
# cargo build -q -p gpui_web --example hello_web --target wasm32-unknown-unknown

# # 2. Generate JS bindings with wasm-bindgen
# wasm-bindgen target/wasm32-unknown-unknown/debug/examples/hello_web.wasm \
#     --out-dir crates/gpui_web/web/pkg \
#     --target web

# # 3. Serve the web directory
# cd crates/gpui_web/web
# python3 -m http.server 8080

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
CRATE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
REPO_ROOT="$(cd "$CRATE_DIR/../.." && pwd)"
OUT_DIR="$CRATE_DIR/web/pkg"

PROFILE="debug"
CARGO_FLAGS="-q"

if [[ "${1:-}" == "--release" ]]; then
    PROFILE="release"
    CARGO_FLAGS="-q --release"
fi

echo "Building hello_web example ($PROFILE)..."
cargo build $CARGO_FLAGS \
    -p gpui_web \
    --example hello_web \
    --target wasm32-unknown-unknown

WASM_PATH="$REPO_ROOT/target/wasm32-unknown-unknown/$PROFILE/examples/hello_web.wasm"

echo "Generating JS bindings..."
mkdir -p "$OUT_DIR"
wasm-bindgen "$WASM_PATH" \
    --out-dir "$OUT_DIR" \
    --target web

WASM_SIZE=$(du -h "$OUT_DIR/hello_web_bg.wasm" | cut -f1)
echo "Done. Output in $OUT_DIR ($WASM_SIZE)"
echo ""
echo "To run, serve the web directory:"
echo "  cd $CRATE_DIR/web && python3 -m http.server 8080"
echo "  open http://localhost:8080"
