#!/usr/bin/env bash

set -euo pipefail

# Creates an Arch Linux .pkg.tar.zst package from pre-built binaries.
#
# This script does NOT build the binaries. It expects them to already exist
# under target/release/ (produced by a prior cargo build step).
#
# Usage: ./script/package-arch-linux

channel=$(<crates/zed/RELEASE_CHANNEL)
target_dir="${CARGO_TARGET_DIR:-target}"

version="$(script/get-crate-version zed)"
commit=$(git rev-parse HEAD | cut -c 1-7)

suffix=""
if [ "$channel" != "stable" ]; then
  suffix="-$channel"
fi

if [[ "$channel" == "nightly" ]]; then
  pkgname="zed-nightly"
  app_name="Zed Nightly"
  app_id="dev.zed.Zed-Nightly"
elif [[ "$channel" == "preview" ]]; then
  pkgname="zed-preview"
  app_name="Zed Preview"
  app_id="dev.zed.Zed-Preview"
elif [[ "$channel" == "dev" ]]; then
  pkgname="zed-dev"
  app_name="Zed Devel"
  app_id="dev.zed.Zed-Dev"
else
  pkgname="zed"
  app_name="Zed"
  app_id="dev.zed.Zed"
fi

# pkgver follows Arch convention: version.commit
pkgver="${version}.${commit}"
pkgrel=1
builddate=$(date +%s)

# Create fakeroot package structure
pkg_root=$(mktemp -d)
trap 'rm -rf "$pkg_root"' EXIT

install_dir="${pkg_root}/pkg"

# Install binaries
mkdir -p "${install_dir}/usr/bin" "${install_dir}/usr/libexec"
cp "${target_dir}/release/zed" "${install_dir}/usr/bin/zed-editor"
cp "${target_dir}/release/remote_server" "${install_dir}/usr/libexec/zed-remote-server"

# Install CLI binary if it exists
if [[ -f "${target_dir}/release/cli" ]]; then
  cp "${target_dir}/release/cli" "${install_dir}/usr/bin/zed"
else
  # Build cli if not already available
  cargo build --release --package cli
  cp "${target_dir}/release/cli" "${install_dir}/usr/bin/zed"
fi

# Install desktop file
mkdir -p "${install_dir}/usr/share/applications"
export DO_STARTUP_NOTIFY="true"
export APP_CLI="zed"
export APP_ICON="zed"
export APP_ARGS="%U"
export APP_NAME="${app_name}"
envsubst '$APP_NAME $APP_CLI $APP_ICON $APP_ARGS $DO_STARTUP_NOTIFY' < "crates/zed/resources/zed.desktop.in" > "${install_dir}/usr/share/applications/${app_id}.desktop"
chmod 644 "${install_dir}/usr/share/applications/${app_id}.desktop"

# Install icons
mkdir -p "${install_dir}/usr/share/icons/hicolor/512x512/apps"
cp "crates/zed/resources/app-icon${suffix}.png" "${install_dir}/usr/share/icons/hicolor/512x512/apps/zed.png"
mkdir -p "${install_dir}/usr/share/icons/hicolor/1024x1024/apps"
cp "crates/zed/resources/app-icon${suffix}@2x.png" "${install_dir}/usr/share/icons/hicolor/1024x1024/apps/zed.png"

# Install metainfo XML (skip @release_info@ placeholder: replace with empty string)
mkdir -p "${install_dir}/usr/share/metainfo"
if [[ "$channel" == "preview" ]]; then
  export BRANDING_LIGHT="#f5f5f5"
  export BRANDING_DARK="#2b2b2b"
elif [[ "$channel" == "nightly" ]]; then
  export BRANDING_LIGHT="#e8e8ff"
  export BRANDING_DARK="#1e1e3e"
else
  export BRANDING_LIGHT="#f5f5f5"
  export BRANDING_DARK="#2b2b2b"
fi
export APP_ID="${app_id}"
envsubst '$APP_ID $APP_NAME $BRANDING_LIGHT $BRANDING_DARK' < "crates/zed/resources/flatpak/zed.metainfo.xml.in" \
  | sed 's/@release_info@//' \
  > "${install_dir}/usr/share/metainfo/${app_id}.metainfo.xml"
chmod 644 "${install_dir}/usr/share/metainfo/${app_id}.metainfo.xml"

# Calculate installed size
installed_size=$(du -sb "${install_dir}" | cut -f1)

# Generate .PKGINFO
cat > "${pkg_root}/.PKGINFO" <<PKGINFO
# Generated by script/package-arch-linux
pkgname = ${pkgname}
pkgver = ${pkgver}-${pkgrel}
pkgdesc = A high-performance, multiplayer code editor - ${channel} builds
url = https://zed.dev
builddate = ${builddate}
packager = Unknown
size = ${installed_size}
arch = x86_64
license = Apache-2.0 GPL-3.0-or-later
depend = gcc
depend = curl
depend = openssl
depend = clang
depend = git
depend = alsa-lib
depend = libxkbcommon
depend = fontconfig
depend = freetype2
depend = libgl
depend = wayland
depend = libx11
depend = xcb-util
depend = libxrandr
depend = libxfixes
provides = zed
conflicts = zed
PKGINFO

# Create data.tar.zst from the install directory
# .MTREE is not required for pacman -U to work and is complex to generate correctly.
# Skip it for nightly CI packages.
tar --zstd -cf "${pkg_root}/data.tar.zst" -C "${install_dir}" .

# Assemble the final .pkg.tar.zst
# Format: .PKGINFO + data.tar.zst
output_name="${pkgname}-${pkgver}-${pkgrel}-x86_64.pkg.tar.zst"
output_path="${target_dir}/release/${output_name}"

tar --zstd -cf "${output_path}" -C "${pkg_root}" .PKGINFO data.tar.zst

echo "Arch Linux package created: ${output_path}"
