#!/usr/bin/env bash
#
# Remove Preview callouts from documentation for stable release.
#
# Usage:
#   script/docs-strip-preview-callouts [--dry-run] [--create-pr]
#
# This script finds and removes all Preview callouts from docs:
#   > **Preview:** This feature is available in Zed Preview...
#
# Options:
#   --dry-run     Show what would be changed without modifying files
#   --create-pr   Create a PR with the changes (otherwise just modifies files)
#   --verbose     Show detailed progress
#
# Run this as part of the stable release workflow.

set -euo pipefail

DRY_RUN=false
CREATE_PR=false
VERBOSE=false

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m'

log() {
    if [[ "$VERBOSE" == "true" ]]; then
        echo -e "${BLUE}[strip-preview]${NC} $*" >&2
    fi
}

error() {
    echo -e "${RED}Error:${NC} $*" >&2
    exit 1
}

# Parse arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --create-pr)
            CREATE_PR=true
            shift
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        -h|--help)
            head -22 "$0" | tail -20
            exit 0
            ;;
        *)
            error "Unknown option: $1"
            ;;
    esac
done

# Get repo root
REPO_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$REPO_ROOT"

DOCS_DIR="$REPO_ROOT/docs/src"

# Preview callout pattern - matches the blockquote format
# > **Preview:** This feature is available in Zed Preview. It will be included in the next Stable release.
PREVIEW_PATTERN='> \*\*Preview:\*\*.*'

# Also match multi-line callouts that might have additional text
# We'll use a simple approach: remove lines starting with "> **Preview:**"
# and any immediately following lines that are part of the same blockquote

echo "Searching for Preview callouts in $DOCS_DIR..."

# Find files with preview callouts
files_with_callouts=$(grep -rl "> \*\*Preview:\*\*" "$DOCS_DIR" 2>/dev/null || true)

if [[ -z "$files_with_callouts" ]]; then
    echo "No Preview callouts found."
    exit 0
fi

file_count=$(echo "$files_with_callouts" | wc -l | tr -d ' ')
echo "Found $file_count file(s) with Preview callouts:"
echo ""

for file in $files_with_callouts; do
    relative_path="${file#$REPO_ROOT/}"
    echo "  $relative_path"
    
    if [[ "$VERBOSE" == "true" ]]; then
        grep -n "> \*\*Preview:\*\*" "$file" | while read -r line; do
            echo "    $line"
        done
    fi
done

echo ""

if [[ "$DRY_RUN" == "true" ]]; then
    echo -e "${YELLOW}=== DRY RUN ===${NC}"
    echo ""
    echo "Would remove Preview callouts from the files above."
    echo ""
    echo "Preview of changes:"
    echo ""
    
    for file in $files_with_callouts; do
        relative_path="${file#$REPO_ROOT/}"
        echo "--- $relative_path ---"
        # Show what would be removed
        grep -n "> \*\*Preview:\*\*" "$file" || true
        echo ""
    done
    
    echo -e "${YELLOW}=== END DRY RUN ===${NC}"
    echo ""
    echo "Run without --dry-run to apply changes."
    exit 0
fi

# Apply changes
echo "Removing Preview callouts..."

for file in $files_with_callouts; do
    log "Processing: $file"
    
    # Create temp file
    tmp_file=$(mktemp)
    
    # Remove lines that are preview callouts
    # This handles single-line callouts: > **Preview:** ...
    # For multi-line, we remove the callout line and any continuation lines
    awk '
    BEGIN { in_callout = 0 }
    /^> \*\*Preview:\*\*/ { 
        in_callout = 1
        next 
    }
    in_callout && /^>/ && !/^> \*\*/ {
        # Continuation of blockquote callout
        next
    }
    in_callout && /^$/ {
        # Empty line after callout - keep it but end callout mode
        in_callout = 0
        next
    }
    {
        in_callout = 0
        print
    }
    ' "$file" > "$tmp_file"
    
    # Replace original file
    mv "$tmp_file" "$file"
    
    echo "  Updated: ${file#$REPO_ROOT/}"
done

echo ""
echo -e "${GREEN}Preview callouts removed from $file_count file(s).${NC}"

if [[ "$CREATE_PR" == "true" ]]; then
    echo ""
    echo "Creating PR..."
    
    # Check for changes
    if [[ -z "$(git status --porcelain docs/)" ]]; then
        echo "No changes to commit."
        exit 0
    fi
    
    # Create branch and PR
    BRANCH_NAME="docs/stable-release-$(date +%Y-%m-%d)"
    git checkout -b "$BRANCH_NAME"
    git add docs/src/
    git commit -m "docs: Remove Preview callouts for stable release

Features documented with Preview callouts are now in Stable."
    
    git push -u origin "$BRANCH_NAME"
    
    gh pr create \
        --title "docs: Remove Preview callouts for stable release" \
        --body "This PR removes Preview callouts from documentation for features that are now in Stable.

Files updated:
$(echo "$files_with_callouts" | sed 's|^|• |' | sed "s|$REPO_ROOT/||")" \
        --label "documentation"
    
    echo ""
    echo -e "${GREEN}PR created!${NC}"
else
    echo ""
    echo "Changes applied locally. Review with 'git diff docs/' and commit when ready."
fi
