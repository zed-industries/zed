#!/usr/bin/env bash

set -eu

usage() {
  echo "Usage: $0 [--retag] <major|minor> [target]"
  echo ""
  echo "Triggers the bump_zed_version workflow to perform a release version bump."
  echo ""
  echo "Arguments:"
  echo "  bump_type   Version bump type: major or minor"
  echo "  target      Which channels to bump: all (default), main, preview, or stable"
  echo ""
  echo "Flags:"
  echo "  --retag     Only create tags on existing branches (skip version bumps and commits)"
  exit 1
}

tag_only=false
while [[ "${1:-}" == --* ]]; do
  case "$1" in
    --retag) tag_only=true; shift ;;
    *) echo "error: unknown flag '$1'" >&2; usage ;;
  esac
done

bump_type="${1:-}"
target="${2:-all}"

if [[ "$bump_type" != "major" && "$bump_type" != "minor" ]]; then
  usage
fi

if [[ "$target" != "all" && "$target" != "main" && "$target" != "preview" && "$target" != "stable" ]]; then
  echo "error: invalid target '$target'" >&2
  echo "Valid targets: all, main, preview, stable" >&2
  exit 1
fi

day_of_week=$(date +%u)
if [[ $day_of_week -ne 3 ]]; then
  day_name=$(date +%A)
  echo "Warning: Today is $day_name. Release version bumps are typically only done on Wednesdays."
  read -r -p "Continue anyway? (y/N) " confirm
  if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
    echo "Aborted."
    exit 0
  fi
fi

which gh > /dev/null 2>&1 || {
  echo "error: GitHub CLI (gh) is required but not installed." >&2
  echo "Install it with: brew install gh" >&2
  exit 1
}

echo "Triggering bump_zed_version workflow:"
echo "  bump_type: $bump_type"
echo "  target:    $target"
echo "  tag_only:  $tag_only"
echo ""

gh workflow run bump_zed_version.yml \
  -f bump_type="$bump_type" \
  -f target="$target" \
  -f tag_only="$tag_only"

echo ""
echo "Workflow triggered. Monitor progress at:"
echo "  https://github.com/zed-industries/zed/actions/workflows/bump_zed_version.yml"
