#!/usr/bin/env bash

# Install wild-linker official binaries from GitHub Releases.

set -euo pipefail

if [ "$(uname -s)" != "Linux" ]; then
    echo "Error: This script is intended for Linux systems only."
    exit 1
fi

WILD_REPO="${WILD_REPO:-https://github.com/davidlattimore/wild}"

if [ -n "${WILD_VERSION:-${1:-}}" ]; then
    WILD_VERSION="${WILD_VERSION:-$1}"
else
    echo "Fetching latest wild release..."
    WILD_VERSION="$(curl -fsSL "https://api.github.com/repos/davidlattimore/wild/releases/latest" \
        | grep '"tag_name"' | sed 's/.*"tag_name": *"\([^"]*\)".*/\1/')"
    if [ -z "$WILD_VERSION" ]; then
        echo "Error: Could not determine latest version from GitHub."
        exit 1
    fi
fi

if command -v wild >/dev/null 2>&1 && wild --version | grep -Fq "$WILD_VERSION" ; then
    echo "wild $WILD_VERSION is already installed at $(command -v wild). Skipping."
    exit 0
fi

echo "This will install wild $WILD_VERSION to /usr/local/bin."
if command -v wild >/dev/null 2>&1; then
    echo "  Current version: $(wild --version 2>/dev/null || echo 'unknown')"
fi
printf "Continue? [Y/n] "
read -r answer
case "$answer" in
    [nN]|[nN][oO]) echo "Aborted."; exit 0 ;;
esac

if [ "$(whoami)" = root ]; then SUDO=; else SUDO="$(command -v sudo || command -v doas || true)"; fi

ARCH="$(uname -m)"
WILD_REPO="${WILD_REPO:-https://github.com/davidlattimore/wild}"
WILD_PACKAGE="wild-linker-${WILD_VERSION}-${ARCH}-unknown-linux-gnu"
WILD_URL="${WILD_URL:-$WILD_REPO}/releases/download/$WILD_VERSION/${WILD_PACKAGE}.tar.gz"
DEST_DIR=/usr/local/bin

echo "Downloading from $WILD_URL"
curl -fsSL --output - "$WILD_URL" \
    | $SUDO tar -C ${DEST_DIR} --strip-components=1 --no-overwrite-dir -xzf - \
    "${WILD_PACKAGE}/wild"

cat <<EOF
Wild is installed to ${DEST_DIR}/wild

To make it your default, add or merge these lines into your ~/.cargo/config.toml:

[target.x86_64-unknown-linux-gnu]
linker = "clang"
rustflags = ["-C", "link-arg=--ld-path=wild"]

[target.aarch64-unknown-linux-gnu]
linker = "clang"
rustflags = ["-C", "link-arg=--ld-path=wild"]
EOF
